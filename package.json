{
  "name": "neetallotmentpredictor-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server",
    "postinstall": "npx prisma@5.22.0 generate --schema=server/prisma/schema.prisma",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev": "npx concurrently \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "build": "npm run build:client && npm run build:server"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0"
  }
}
